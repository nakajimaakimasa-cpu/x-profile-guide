# ===========================================
# X (Twitter) API 認証情報
# ===========================================
# Developer Portal (https://developer.x.com/en/portal/dashboard) から取得
#
# 1. App を作成
# 2. Keys and tokens から以下をコピー
# 3. このファイルを .env にリネームして値を入力
# ===========================================

# --- Bearer Token（読み取り専用: ユーザー検索、ツイート検索など） ---
X_BEARER_TOKEN=your_bearer_token_here

# --- API Key & Secret（アプリ認証用） ---
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here

# --- Access Token & Secret（ユーザーコンテキスト: ツイート投稿に必要） ---
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here
